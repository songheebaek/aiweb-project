# 이 파일을 .env 로 복사한 뒤 실제 값을 채우세요.  cp .env.example .env
# ⚠️ 이 .env.example 파일은 git에 올라가므로 실제 키를 절대 여기 넣지 마세요. (키는 .env 에만!)

# Google AI Studio에서 무료 발급: https://aistudio.google.com/apikey
# LLM provider: gemini 또는 openai
LLM_PROVIDER=gemini

# Gemini 사용 시
GOOGLE_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-3.5-flash

# OpenAI/GPT 사용 시
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-5.5

# (선택) 배포 서버/HF Space에서 유튜브가 IP를 막을 때 자막용 프록시.
# youtube-transcript-api 공식 Webshare 방식만 사용합니다.
# - Webshare Residential rotating proxy의 Proxy Username/Password를 넣으세요.
# - username을 `user-gb-1`처럼 변형하지 마세요.
# - 국가 제한은 WEBSHARE_PROXY_LOCATIONS에 ISO 코드로 넣으세요.
# WEBSHARE_PROXY_USERNAME=your-webshare-proxy-username
# WEBSHARE_PROXY_PASSWORD=your-webshare-proxy-password
# WEBSHARE_PROXY_LOCATIONS=kr,jp,us

# (선택) Webshare/YouTube 연결이 중간에 끊길 때 자막 fetch 자동 재시도
# TRANSCRIPT_FETCH_RETRIES=3
# TRANSCRIPT_FETCH_BACKOFF_SECONDS=1.5
