# 이 파일을 .env 로 복사한 뒤 실제 값을 채우세요.  cp .env.example .env
# ⚠️ 이 .env.example 파일은 git에 올라가므로 실제 키를 절대 여기 넣지 마세요. (키는 .env 에만!)

# Google AI Studio에서 무료 발급: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# (선택) 모델 교체용. 기본값 gemini-3-flash-preview. (안정적인 비-프리뷰: gemini-3.5-flash)
# GEMINI_MODEL=gemini-3-flash-preview

# (선택) 배포 서버에서 유튜브가 IP를 막을 때 자막용 프록시.
# PROXY_URL=http://user:pass@host:port
